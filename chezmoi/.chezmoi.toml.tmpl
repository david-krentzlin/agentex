{{- $develop := promptBoolOnce . "develop" "Will you develop on this machine" -}}
{{- $needsOpencode := promptBoolOnce . "needs_opencode" "Will you need opencode on this machine" -}}
{{- $needsTaskwarrior := promptBoolOnce . "needs_taskwarrior" "Should Taskwarrior be installed on this machine" -}}
{{- $manageLimaVmsFromThisHost := promptBoolOnce . "manage_lima_vms_from_this_host" "Do you manage Lima VMs from this host" -}}
{{- $buildHelixFromSource := false -}}
{{- if $develop -}}
{{- $buildHelixFromSource = promptBoolOnce . "build_helix_from_source" "Should Helix be built from source on this machine" -}}
{{- end -}}
{{- $workUsername := promptStringOnce . "work_username" "Work username (leave blank if not applicable)" -}}
[data]
develop = {{ $develop }}
needs_opencode = {{ $needsOpencode }}
needs_taskwarrior = {{ $needsTaskwarrior }}
manage_lima_vms_from_this_host = {{ $manageLimaVmsFromThisHost }}
build_helix_from_source = {{ $buildHelixFromSource }}
name = {{ promptStringOnce . "name" "Git author name" | quote }}
email = {{ promptStringOnce . "email" "Git author email" | quote }}
github_username = {{ promptStringOnce . "github_username" "GitHub username" | quote }}
work_username = {{ $workUsername | quote }}

[warnings]
configFileTemplateHasChanged = false
