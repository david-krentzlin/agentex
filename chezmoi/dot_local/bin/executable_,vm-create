#!/usr/bin/env bash
set -euo pipefail

if ! command -v chezmoi >/dev/null 2>&1; then
	echo "Error: chezmoi is required but was not found on PATH." >&2
	exit 1
fi

SOURCE_DIR="$(chezmoi source-path)"

for candidate in \
	"$SOURCE_DIR/bootstrap/vm/macos-create-fedora.sh" \
	"$SOURCE_DIR/../bootstrap/vm/macos-create-fedora.sh"; do
	if [[ -f "$candidate" ]]; then
		exec "$candidate" "$@"
	fi
done

echo "Error: could not locate bootstrap/vm/macos-create-fedora.sh from chezmoi source path '$SOURCE_DIR'." >&2

exit 1
